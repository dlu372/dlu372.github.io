---
import { Image } from 'astro:assets';
import profile from '../../source-materials/profile.PNG';
import '../styles/global.css';

const cvPath = `${import.meta.env.BASE_URL}files/Di-Lu-CV.pdf`;

const links = [
  { label: 'University profile', href: 'https://profiles.auckland.ac.nz/dlu372' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/di-lu-/' },
  { label: 'GitHub', href: 'https://github.com/dlu372?tab=repositories' },
];

const updates = [
  {
    date: '2026',
    text: 'Joined the University of Auckland as a Teaching Assistant in Information Systems and Operations Management.',
  },
  {
    date: '2026',
    text: 'Completed an information and data internship with Bay of Plenty Regional Council, delivering reporting, migration, and governance work across multiple teams.',
  },
  {
    date: '2026',
    text: 'Launched an interactive airline network analytics case study, combining a reproducible Python and SQL pipeline with a publicly accessible web dashboard.',
  },
  {
    date: '2025',
    text: 'Received a Certificate of Distinction in Statistics for Commerce at the University of Auckland.',
  },
];

const projects = [
  {
    title: 'Airline Network Structure & Connectivity Analytics',
    meta: 'Python · SQL · Interactive Dashboard · 2026',
    description:
      'Re-engineered a historical airline network analysis into a reproducible, quality-validated data product spanning 52,296 route presences. The interactive dashboard compares network breadth, geographic reach, hub dependence, and codeshare-associated reach with clear methodology and data-quality controls.',
    links: [
      {
        label: 'View live dashboard',
        href: 'https://dlu372.github.io/Airline-Analytics-Project/',
      },
      {
        label: 'View source code',
        href: 'https://github.com/dlu372/Airline-Analytics-Project',
      },
    ],
  },
  {
    title: 'GenAI Learning Analytics Research',
    meta: 'Qualitative research · University of Auckland · 2025',
    description:
      'A research collaboration investigating how students incorporate generative AI into learning and problem-solving workflows, with insights for responsible adaptive learning systems.',
  },
  {
    title: 'DocAdvisor',
    meta: 'AI product · Team leadership · Web development · 2023',
    description:
      'An AI-enabled healthcare prototype developed with a ten-person student team. I led product strategy and validation, translated user needs into product logic, and independently built the project website.',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="Di Lu works across information systems, business analytics, data products, and AI-enabled workflows in Auckland, New Zealand."
    />
    <meta name="theme-color" content="#f4f1ea" />
    <title>Di Lu — Information Systems & Business Analytics</title>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>

    <header class="site-header">
      <a class="wordmark" href="#top" aria-label="Di Lu, home">Di Lu</a>
      <nav aria-label="Primary navigation">
        <a href="#about">About</a>
        <a href="#experience">Experience</a>
        <a href="#projects">Projects</a>
        <a href="#education">Education</a>
      </nav>
    </header>

    <div class="page-shell" id="top">
      <aside class="profile-card" aria-label="Profile">
        <Image
          class="portrait"
          src={profile}
          alt="Professional portrait of Di Lu"
          width={1254}
          height={1254}
          quality={90}
          loading="eager"
        />
        <div class="profile-copy">
          <p class="eyebrow">Auckland, New Zealand</p>
          <h1>Di Lu</h1>
          <p class="role">Information Systems & Business Analytics</p>
          <p class="affiliation">The University of Auckland</p>
        </div>

        <div class="contact-list">
          <a href="mailto:dilu.connect@gmail.com">dilu.connect@gmail.com</a>
          {links.map((link) => (
            <a href={link.href} target="_blank" rel="noreferrer">
              {link.label}<span aria-hidden="true"> ↗</span>
            </a>
          ))}
        </div>

        <p class="availability">
          Graduating November 2026 · Open to graduate and early-career opportunities
        </p>
      </aside>

      <main id="main">
        <section class="intro section" id="about" aria-labelledby="about-title">
          <p class="section-kicker">Profile</p>
          <h2 id="about-title">Turning complex information into useful decisions.</h2>
          <p class="lede">
            I work across information systems, business analytics, and digital operations—turning ambiguous problems and messy data into reliable data products, clearer workflows, and practical decisions.
          </p>
          <p>
            My path spans China and New Zealand. I spent the first 18 months of my undergraduate study in Information Management & Systems at <a href="https://www.topuniversities.com/universities/university-science-technology-beijing" target="_blank" rel="noopener noreferrer">USTB</a>, a Top 30 university in China, where I led applied AI projects, before transferring to the University of Auckland. I have worked in NZ local government Information & Data Team and currently serve as a Teaching Assistant at the University of Auckland.
          </p>
          <a class="text-link" href={cvPath} target="_blank" rel="noopener noreferrer">
            View CV <span aria-hidden="true">↗</span>
          </a>

          <div class="focus-grid" aria-label="Areas of focus">
            <div>
              <span>01</span>
              <h3>Data products</h3>
              <p>Governed datasets, automated reporting workflows, interactive dashboards, and decision-ready analysis.</p>
            </div>
            <div>
              <span>02</span>
              <h3>Business analysis</h3>
              <p>Requirements discovery, process modelling, stakeholder alignment, and practical solution design.</p>
            </div>
            <div>
              <span>03</span>
              <h3>AI-enabled solutions</h3>
              <p>Responsible automation, AI-enabled workflows, product thinking, and practical implementation.</p>
            </div>
          </div>
        </section>

        <section class="section" aria-labelledby="updates-title">
          <div class="section-heading">
            <p class="section-kicker">Recent</p>
            <h2 id="updates-title">Updates</h2>
          </div>
          <ol class="updates-list">
            {updates.map((update) => (
              <li>
                <time>{update.date}</time>
                <p>{update.text}</p>
              </li>
            ))}
          </ol>
        </section>

        <section class="section" id="experience" aria-labelledby="experience-title">
          <div class="section-heading">
            <p class="section-kicker">Selected</p>
            <h2 id="experience-title">Experience</h2>
          </div>

          <div class="timeline">
            <article>
              <div class="timeline-meta">
                <time>2026 — Present</time>
                <p>Auckland, NZ</p>
              </div>
              <div>
                <h3>Teaching Assistant</h3>
                <p class="organisation">The University of Auckland · ISOM Department</p>
                <p>Facilitate tutorials in Digital Strategy and Transformation, helping students evaluate organisations, emerging technologies, and AI-enabled change with clear evidence and practical recommendations.</p>
              </div>
            </article>

            <article>
              <div class="timeline-meta">
                <time>2025 — 2026</time>
                <p>Bay of Plenty, NZ</p>
              </div>
              <div>
                <h3>Summer Assistant, Information & Data</h3>
                <p class="organisation">Bay of Plenty Regional Council</p>
                <p>Delivered data products across records, service requests, assets, and environmental operations. Built Python, SQL, Power Query, and Power BI workflows while supporting migration, metadata, permissions, and sustainable handover.</p>
              </div>
            </article>

            <article>
              <div class="timeline-meta">
                <time>2023</time>
                <p>Beijing, China</p>
              </div>
              <div>
                <h3>Team Lead, DocAdvisor Project</h3>
                <p class="organisation">University of Science and Technology Beijing</p>
                <p>Led a ten-person research and practice team to develop and validate an AI-enabled healthcare prototype, coordinating product direction, stakeholder communication, website delivery, and public storytelling.</p>
              </div>
            </article>
          </div>
        </section>

        <section class="section" id="projects" aria-labelledby="projects-title">
          <div class="section-heading">
            <p class="section-kicker">Selected</p>
            <h2 id="projects-title">Projects</h2>
          </div>
          <div class="project-list">
            {projects.map((project, index) => (
              <article>
                <p class="project-number">0{index + 1}</p>
                <div>
                  <h3>{project.title}</h3>
                  <p class="project-meta">{project.meta}</p>
                  <p>{project.description}</p>
                  {project.links?.map((link, linkIndex) => (
                    <>
                      {linkIndex > 0 && <br />}
                      <a
                        class="text-link"
                        href={link.href}
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        {link.label} <span aria-hidden="true">↗</span>
                      </a>
                    </>
                  ))}
                </div>
              </article>
            ))}
          </div>
        </section>

        <section class="section" id="education" aria-labelledby="education-title">
          <div class="section-heading">
            <p class="section-kicker">Background</p>
            <h2 id="education-title">Education & recognition</h2>
          </div>
          <div class="education-grid">
            <article>
              <p class="date">2024 — 2026</p>
              <h3>Bachelor of Commerce</h3>
              <p class="organisation">The University of Auckland</p>
              <p>Information Systems and Business Analytics</p>
	      <p>Overall average: A−</p>
            </article>
            <article>
              <p class="date">2022 — 2024</p>
              <h3>Information Management & Information Systems</h3>
              <p class="organisation">University of Science and Technology Beijing</p>
              <p>GPA 3.74 / 4.00 · Top 20%</p>
            </article>
          </div>
          <section class="coursework" aria-labelledby="coursework-title">
            <h3 id="coursework-title">Selected relevant coursework</h3>
            <ul class="coursework-list">
              <li><span>Statistics for Commerce</span><strong>A+</strong></li>
              <li><span>Machine Learning</span><strong>A</strong></li>
              <li><span>Data Wrangling and Big Data</span><strong>A</strong></li>
              <li><span>Data Management</span><strong>A</strong></li>
              <li><span>Digital Business and Innovation</span><strong>A</strong></li>
              <li><span>Digital Strategy and Transformation</span><strong>A-</strong></li>
              <li><span>Business Systems Analysis</span><strong>A-</strong></li>
              <li><span>Project Management</span><strong>A</strong></li>
            </ul>
          </section>
          <div class="recognition">
            <p>International Student Excellence Scholarship</p>
            <p>Certificate of Distinction — Statistics for Commerce</p>
            <p>Best Product Prototype Award — DocAdvisor</p>
          </div>
        </section>

        <footer>
          <p>Let’s make information clearer, more useful, and easier to act on.</p>
          <a href="mailto:dilu.connect@gmail.com">Get in touch</a>
          <small>© {new Date().getFullYear()} Di Lu</small>
        </footer>
      </main>
    </div>
  </body>
</html>
